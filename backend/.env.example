# ─────────────────────────────────────────────────────────────────────────────
# Docker Mailserver UI — environment configuration
#
# Copy this file to `.env` and adjust the values. Everything has a sane default,
# including SECRET_KEY (auto-generated and persisted on first startup if unset).
# All variables are optional unless stated otherwise.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────

# Directory holding persistent data (SQLite database). Mounted as a volume in
# docker-compose.
DATA_DIR=/var/lib/mailserver-ui

# ── Mailserver management (docker exec) ──────────────────────────────────────
#
# All mailserver management (mailboxes, aliases, relays, DKIM, mail log, …) runs
# inside the mailserver container via `docker exec`: the app reads and writes the
# docker-mailserver config files there, and runs runtime-only commands. No config
# directory is bind-mounted. This REQUIRES the Docker socket to be mounted into
# this container, e.g. add `- /var/run/docker.sock:/var/run/docker.sock` to the
# service volumes. Note: mounting the Docker socket grants this container
# root-equivalent control of the host — only mount it if you accept that.
#
# Name (or ID) of the docker-mailserver container to exec into.
MAILSERVER_CONTAINER=mailserver
# Timeout (seconds) for a single mailserver `docker exec` command.
MAILSERVER_COMMAND_TIMEOUT=30
# Number of trailing mail log lines returned by the mail log view.
MAILSERVER_LOG_LINES=200
# Trailing time window the dashboard mail statistics report on.
MAILSERVER_STATS_HOURS=24
# Trailing mail log lines scanned to build those statistics. A busy server can
# overflow this window; the dashboard shows how many lines were actually read.
MAILSERVER_STATS_LOG_LINES=20000

# ── Fail2ban ─────────────────────────────────────────────────────────────────
#
# Fail2ban is driven the same way (`docker exec`), so it also needs the Docker
# socket mounted (see above). The views are active only when the mailserver
# container itself runs with `ENABLE_FAIL2BAN=1`; there is nothing to enable here.
#
# Timeout (seconds) for a single fail2ban command.
FAIL2BAN_COMMAND_TIMEOUT=15
# Number of trailing fail2ban log lines returned by the log view.
FAIL2BAN_LOG_LINES=200

# SQLite connection string. Defaults to a file under DATA_DIR.
# DATABASE_URL=sqlite:////var/lib/mailserver-ui/mailserver-ui.db
# Echo SQL statements to the logs (debug only).
DATABASE_ECHO=false

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Authentication ───────────────────────────────────────────────────────────

# Signs the session/JWT cookies. Optional: if left unset, a random key is
# generated on first startup and persisted to `DATA_DIR/secret_key` so sessions
# survive restarts. Set it explicitly to control the value (recommended when
# running multiple replicas), e.g. `openssl rand -hex 32`.
# SECRET_KEY=

# Username of the default admin seeded on first startup. Its password is
# generated randomly and printed ONCE to the logs — capture it then.
ADMIN_USERNAME=admin

# Session cookie settings. The cookie `Secure` flag is detected automatically
# from the request scheme (https), honouring X-Forwarded-Proto when behind a
# trusted proxy (see TRUSTED_PROXIES) — no manual toggle needed.
AUTH_COOKIE_NAME=pc_token
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Personal access tokens (PAT) ─────────────────────────────────────────────
#
# Users issue tokens from their profile to call the REST API without a browser
# session. A token (`pat_…`) carries the effective role of the account that owns
# it, and is presented as `Authorization: Bearer <token>`.
PATS_ENABLED=true
# Upper bound on the number of live tokens a single account may own.
PAT_MAX_PER_USER=10

# ── OIDC / SSO (first-boot seed only) ────────────────────────────────────────
#
# NOTE: OIDC is now configured from the web UI (Settings → OIDC / SSO) and
# stored in the database. The variables below are read ONLY on the very first
# startup to seed the initial configuration (backwards compatibility). Once the
# database row exists, editing these variables has no effect — use the UI.

OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_POST_LOGOUT_REDIRECT_URI=
OIDC_RESPONSE_TYPE=code
OIDC_SCOPE=openid profile email groups
# Force SSO by disabling local username/password login.
OIDC_ONLY=false
# Group-based role mapping. Members of OIDC_ADMIN_GROUP sign in as
# administrators, members of OIDC_MANAGER_GROUP as mailbox managers. Anyone in
# neither group signs in as a guest (dashboard only), unless
# OIDC_RESTRICT_TO_GROUPS denies them access altogether.
OIDC_ADMIN_GROUP_CLAIM=
OIDC_ADMIN_GROUP=
OIDC_MANAGER_GROUP_CLAIM=
OIDC_MANAGER_GROUP=
OIDC_RESTRICT_TO_GROUPS=false

# ── Mail connector (first-boot seed only) ────────────────────────────────────
#
# Like OIDC, the connector is configured from the web UI (Settings → Mail
# connector) and stored in the database. The variables below seed the row the
# very first time it is read; afterwards, use the UI.
#
# It sends notifications for audit events — either sign-in/sign-out alone, or the
# whole audit trail — and backs the "send a test message" button.

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# STARTTLS on a plaintext connection (587) vs implicit TLS (465). Set one, not both.
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM=
# Comma-separated list of notification recipients.
SMTP_RECIPIENTS=
# Notify on sign-in/sign-out only…
SMTP_NOTIFY_AUTH_EVENTS=false
# …or on every audit event (sign-in and sign-out included).
SMTP_NOTIFY_AUDIT_EVENTS=false

# ── Audit trail ──────────────────────────────────────────────────────────────

# Entries older than this many days are purged on startup. 0 keeps them forever.
AUDIT_RETENTION_DAYS=0

# ── Reverse proxy & rate limiting ────────────────────────────────────────────

# Comma-separated list of trusted proxy IPs so the real client IP is used
# behind a reverse proxy (required for correct rate limiting).
TRUSTED_PROXIES=

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_LOGIN_PATH=/api/auth/login

# ── API docs ─────────────────────────────────────────────────────────────────

# Expose the Swagger UI at /api/docs (disabled by default).
SWAGGER_ENABLED=false
